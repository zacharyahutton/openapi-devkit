{
  "openapi": "3.0.0",
  "info": { "title": "Pet Store Demo", "version": "1.0.0" },
  "paths": {
    "/pets": {
      "get": { "operationId": "listPets", "summary": "List pets" },
      "post": { "operationId": "createPet", "summary": "Create a pet" }
    },
    "/pets/{id}": {
      "get": { "operationId": "getPet", "summary": "Get pet by ID" }
    }
  },
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "tag": { "type": "string" }
        }
      }
    }
  }
}