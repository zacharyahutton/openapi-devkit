{
  "name": "openapi-devkit",
  "version": "0.1.0",
  "description": "Portfolio demonstration \u2014 OpenAPI to TypeScript client codegen starter",
  "type": "module",
  "bin": {
    "openapi-devkit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test tests/cli.test.js",
    "demo": "npm run build && node dist/cli.js --input examples/petstore.json --list-endpoints"
  },
  "keywords": [
    "openapi",
    "codegen",
    "typescript",
    "portfolio"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
